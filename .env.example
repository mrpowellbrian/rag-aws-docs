# Copy to .env and fill in values. .env is gitignored.

# Required for generation
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override embedding model (default: all-MiniLM-L6-v2)
# EMBEDDING_MODEL=all-MiniLM-L6-v2

# Optional: override LLM model (default: claude-haiku-4-5-20251001)
# LLM_MODEL=claude-haiku-4-5-20251001

# Optional: override chunk settings
# CHUNK_SIZE=512
# CHUNK_OVERLAP=64
# TOP_K=5

# Optional: Chroma persistence directory (default: ./chroma_db)
# CHROMA_PATH=./chroma_db

# Optional: OpenAI embeddings (requires pip install rag-aws-docs[openai])
# EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# Optional: AWS Bedrock (requires pip install rag-aws-docs[bedrock])
# LLM_PROVIDER=bedrock
# AWS_REGION=us-east-1
